    #     # apply dz relative to TCP
    #     local base_pose_for_target = p[interp[0], interp[1], interp[2], interp[3], interp[4], interp[5]]
    #     local target_pose = pose_trans(base_pose_for_target, p[0,0,dz_scaled,0,0,0])

    #     textmsg("brune")

    #     # small orientation correction
    #     local rot = orientation_correction(T_tcp, Fz)
    #     textmsg("orange")
    #     if (rot[0] != 0.0) or (rot[1] != 0.0):
    #     target_pose = pose_trans(target_pose, p[0,0,0, rot[0], rot[1], rot[2]])
    #     end

    #     textmsg("rude")

    #     # move the robot
    #     servoj([target_pose[0], target_pose[1], target_pose[2], target_pose[3], target_pose[4], target_pose[5]],
    #     servoj_acc, servoj_vel, control_period, 0.05, 300)
    #     textmsg("here")
    #     sync()
    #     i = i + 1
    # end
    # end
    # ----------------------------------------------------

    def bow(bow_dir, note_dur, bow_poses):
        if note_dur > 3:
            note_dur = 3
        end

        # ease scale for distance
        local dist_scale = ease_scale(note_dur)

        local tip_p = bow_poses.tip_p
        local frog_p = bow_poses.frog_p

        # element-wise difference
        local diff = [tip_p[0]-frog_p[0], tip_p[1]-frog_p[1], tip_p[2]-frog_p[2]]
        local n = norm(diff)
        local direction_vector = [diff[0]/n, diff[1]/n, diff[2]/n]

        local tcp_pose = get_actual_tcp_pose()
        local start_p = [tcp_pose[0], tcp_pose[1], tcp_pose[2], tcp_pose[3], tcp_pose[4], tcp_pose[5]]
        local end_p = frog_p
        local t_dir = -1

        if bow_dir != 0:
            end_p = tip_p
            t_dir = 1
        end

        # target distance along bow
        local target_dist = dist_scale * sqrt((tip_p[0]-frog_p[0])*(tip_p[0]-frog_p[0]) +
                                            (tip_p[1]-frog_p[1])*(tip_p[1]-frog_p[1]) +
                                            (tip_p[2]-frog_p[2])*(tip_p[2]-frog_p[2]))

        # compute element-wise step vector
        local step_vec = [(end_p[0]-start_p[0])/max(1, round(note_dur/control_period)),
                        (end_p[1]-start_p[1])/max(1, round(note_dur/control_period)),
                        (end_p[2]-start_p[2])/max(1, round(note_dur/control_period)),
                        (end_p[3]-start_p[3])/max(1, round(note_dur/control_period)),
                        (end_p[4]-start_p[4])/max(1, round(note_dur/control_period)),
                        (end_p[5]-start_p[5])/max(1, round(note_dur/control_period))]

        local steps = round(note_dur / control_period)
        if steps < 1:
            steps = 1
        end

        textmsg("bruj")

        local i = 1
        while i <= steps:
            # desired interpolated pose
            local interp = [start_p[0]+step_vec[0]*i,
                            start_p[1]+step_vec[1]*i,
                            start_p[2]+step_vec[2]*i,
                            start_p[3]+step_vec[3]*i,
                            start_p[4]+step_vec[4]*i,
                            start_p[5]+step_vec[5]*i]

            # ------------------------
            # read actual force (Fz) and torque
            local res2 = measure_fused_Fz_and_torque()
            local Fz = res2[0]
            local T_tcp = res2[1]
            # ------------------------
            textmsg("got through")

            # ---------- gentle force ramp ----------
            local ramp_frac = min(1.0, i / 30.0)   # ramp over first 30 steps
            local F_desired = ramp_frac * target_force
            local error = F_desired - Fz
            local dz = ramp_frac * admittance_gain * error

            # clamp dz
            if dz > max_offset:
                dz = max_offset
            elif dz < -max_offset:
                dz = -max_offset
            end

            # apply dz along Z
            local base_pose_for_target = p[interp[0], interp[1], interp[2], interp[3], interp[4], interp[5]]
            local target_pose = pose_trans(base_pose_for_target, p[0,0,dz,0,0,0])

            # small orientation correction
            textmsg("blue")
            local rot = orientation_correction(T_tcp, Fz)
            if rot[0] != 0.0 or rot[1] != 0.0:
                target_pose = pose_trans(target_pose, p[0,0,0, rot[0], rot[1], rot[2]])
            end

            # move the robot gently
            servoj([target_pose[0], target_pose[1], target_pose[2], target_pose[3], target_pose[4], target_pose[5]],
       servoj_acc, servoj_vel, control_period, 0.05, 300)

            sync()
            i = i + 1
        end
    end



  def stay():
    stopj(2.5)
    sleep(0.025)
  end

  def a_bow(bow_dir, note_dur):
    _event_flag = 1  # START a_bow
    write_output_integer_register(0, _event_flag)
    write_output_integer_register(1, bow_dir)
    bow(bow_dir, note_dur, a_bow_poses)
    _event_flag = 2  # END a_bow
    write_output_integer_register(0, _event_flag)
  end

  def d_bow(bow_dir, note_dur):
    _event_flag = 3  # START d_bow
    write_output_integer_register(1, bow_dir)
    write_output_integer_register(0, _event_flag)
    bow(bow_dir, note_dur, d_bow_poses)
    _event_flag = 4  # END d_bow
    write_output_integer_register(0, _event_flag)
  end

  def g_bow(bow_dir, note_dur):
    _event_flag = 5  # START g_bow
    write_output_integer_register(1, bow_dir)
    write_output_integer_register(0, _event_flag)
    bow(bow_dir, note_dur, g_bow_poses)
    _event_flag = 6  # END g_bow
    write_output_integer_register(0, _event_flag)
  end

  def c_bow(bow_dir, note_dur):
    _event_flag = 7  # START c_bow
    write_output_integer_register(1, bow_dir)
    write_output_integer_register(0, _event_flag)
    bow(bow_dir, note_dur, c_bow_poses)
    _event_flag = 8  # END c_bow
    write_output_integer_register(0, _event_flag)
  end

  def round(n):
    local int_part = floor(n)
    if (n - int_part) >= 0.5:
        return int_part + 1
    else:
        return int_part
    end
  end

  def min(a, b):
    if a < b:
      return a
    else:
      return b
    end
  end

  def max(a, b):
    if a > b:
      return a
    else:
      return b
    end
  end

  def dot(a, b):
    return a[0]*b[0] + a[1]*b[1] + a[2]*b[2]
  end

  def string_crossing(start_bow_poses, end_bow_poses, next_dir):
    # we first find the curr position
    local tcp_pose = get_actual_tcp_pose()
    local start_p = [tcp_pose[0], tcp_pose[1], tcp_pose[2], tcp_pose[3], tcp_pose[4], tcp_pose[5]]

    local out = [0.89583677, 0.04158029, 0.44243367, 0, 0, 0]
    local step1 = start_p + out * 0.03
    
    movep(p[step1[0], step1[1], step1[2], start_p[3], start_p[4], start_p[5]])
    movep(p[step1[0], step1[1], step1[2], d_bow_poses.frog_p[3], d_bow_poses.frog_p[4], d_bow_poses.frog_p[5]])
    sync()

    tcp_pose = get_actual_tcp_pose()
    start_p = [tcp_pose[0], tcp_pose[1], tcp_pose[2], tcp_pose[3], tcp_pose[4], tcp_pose[5]]
    local bow_vec = end_bow_poses.tip_p - end_bow_poses.frog_p
    local direction_vector = bow_vec / norm(bow_vec)
    local A = end_bow_poses.tip_p
    local target_pose = dot(start_p - A, direction_vector) / dot(direction_vector, direction_vector) * direction_vector + A
    

    movep(p[target_pose[0], target_pose[1], target_pose[2], target_pose[3], target_pose[4], target_pose[5]], v=3.67)
    # sync()

  end

  def a_to_d(next_dir=0):
    _event_flag = 101
    write_output_integer_register(0, _event_flag)
    string_crossing(a_bow_poses, d_bow_poses, next_dir)
    _event_flag = 102
    write_output_integer_register(0, _event_flag)
  end

  def a_to_g(next_dir=0):
