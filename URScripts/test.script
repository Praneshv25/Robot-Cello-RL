  popup("Started song()")
  global _event_flag = 0

  global a_bow_poses = struct(
    tip_p=[.473129539189, .413197423330, .256308427905, -1.460522581833, -2.310115543652, 1.445803824327], 
    frog_p=[.300717266074, .793568239540, .099710283103, -1.543522183454, -2.354885618328, 1.346770272474]
  )

  global d_bow_poses = struct(
    tip_p=[.340413993945, .280157415162, .176342071758, -1.614553612482, -2.044810993523, 1.042279199535],
    frog_p=[.302785064368, .749849181019, .117254426008, -1.664082298752, -2.084265434693, 1.037965163360]
  )

  global g_bow_poses = struct(
    tip_p=[.162016291992, .201320984957, .059414774157, -1.929772636560, -1.931323067217, .555055912517], 
    frog_p=[.281203376642, .681662588607, .104672526365, -1.812194031755, -1.940153681829, .493747597283]
  )

  global c_bow_poses = struct(
    tip_p=[.079815569355, .285182178102, -.086654726588, -1.819646014269, -1.658258006768, .180930717120],
    frog_p=[.256662516098, .610082591416, .062624387196, -1.743236422252, -1.524514092756, .163823228357]
  )

  # ---- Force-control & lever-arm parameters (tune these) ----
  global r_tool = [0.0, 0.6096, 0.0]    # [x,y,z] in meters (tool frame). Set this from frog TCP -> contact point measurement.
  global target_force = 0.5          # desired normal force at contact (N) — tune
  global admittance_gain = 0.002      # dz = gain * (target - measured); start small
  global max_offset = 0.005            # max Z correction per step (m)
  global control_period = 0.02        # seconds per control step
  global servoj_acc = 0.05
  global servoj_vel = 0.02
  global fuse_alpha = 0.8             # weight for linear Fz projection vs torque-derived estimate
  global orient_comp_gain = 0.00008    # small orientation correction gain (rad per Nm)
  # ----------------------------------------------------------

  def ease_scale(note_dur):
    if note_dur > 3:
        note_dur = 3
    end

    return (1.0 - cos(3.14159265359 * note_dur / 3.0)) / 2.0
  end


  def cross(a, b):
    return [ a[1]*b[2] - a[2]*b[1],
             a[2]*b[0] - a[0]*b[2],
             a[0]*b[1] - a[1]*b[0] ]
  end
  # ------------------------------------------------------

  # ---------- compute unit tool-Z in base frame ----------
  def get_tool_z_hat():
    local tcp = get_actual_tcp_pose()   # base-frame pose
    local zpt = pose_trans(tcp, p[0,0,0.01,0,0,0])  # 1cm along tool Z in base frame
    local zd = [zpt[0]-tcp[0], zpt[1]-tcp[1], zpt[2]-tcp[2]]
    local n = norm(zd)
    if n == 0:
      return [0,0,1]
    end
    return [zd[0]/n, zd[1]/n, zd[2]/n]
  end
  # -------------------------------------------------------

  # ---------- transform r_tool (tool frame) to base frame -------
  def r_tool_to_base(r_tool_param):
    local tcp = get_actual_tcp_pose()
    local contact_pose = pose_trans(tcp, p[r_tool_param[0], r_tool_param[1], r_tool_param[2], 0,0,0])
    return [contact_pose[0]-tcp[0], contact_pose[1]-tcp[1], contact_pose[2]-tcp[2]]
  end
  # ---------------------------------------------------------------

  # ---------- measure & fuse Fz estimate ----------
  def measure_fused_Fz_and_torque():
    # returns a list: [Fz_fused (N), [Tx, Ty, Tz] (Nm)]
    local wrench = get_tcp_force()   # [Fx,Fy,Fz, Tx,Ty,Tz] in base frame
    local F_tcp = [wrench[0], wrench[1], wrench[2]]
    local T_tcp = [wrench[3], wrench[4], wrench[5]]
    textmsg("force", wrench)

    # compute tool z_hat and project linear force onto it
    local z_hat = get_tool_z_hat()
    local Fz_proj = dot(F_tcp, z_hat)

    # torque-derived estimate: assume F ≈ Fz * z_hat and tau ≈ r_base x (Fz * z_hat)
    local r_base = r_tool_to_base(r_tool)
    local r_cross_z = cross(r_base, z_hat)
    local denom = dot(r_cross_z, r_cross_z)
    local Fz_from_tau = 0.0
    if denom > 1e-8:
      Fz_from_tau = dot(T_tcp, r_cross_z) / denom
    else:
      Fz_from_tau = Fz_proj   # fallback when lever arm geometry is degenerate
    end

    # fuse (weighted)
    local Fz_fused = fuse_alpha * Fz_proj + (1.0 - fuse_alpha) * Fz_from_tau
    textmsg("fuze", Fz_fused)

    return [Fz_fused, T_tcp]
  end
  # ----------------------------------------------------

  # ---------- orientation correction (small) ----------
def orientation_correction(T_tcp_param, Fz_fused_param):
    # helper: URScript doesn't have abs() for numbers
    def ur_abs(x):
        if x < 0:
            return -x
        else:
            return x
        end
    end

    local rx = 0.0
    local ry = 0.0

    if ur_abs(Fz_fused_param) > 0.2:
        # proportional correction
        rx = -orient_comp_gain * T_tcp_param[1] / (ur_abs(Fz_fused_param) + 1e-6)
        ry =  orient_comp_gain * T_tcp_param[0] / (ur_abs(Fz_fused_param) + 1e-6)

        # clamp to safe small rotations
        if rx > 0.05:
            rx = 0.05
        elif rx < -0.05:
            rx = -0.05
        end

        if ry > 0.05:
            ry = 0.05
        elif ry < -0.05:
            ry = -0.05
        end
    end

    return [rx, ry, 0.0]
    end
    # ----------------------------------------------------


     # ---------- measure force along tool Z (public helper) ----------
    def measure_force_along_tool_z():
        local res = measure_fused_Fz_and_torque()
        local Fz = res[0]
        return Fz
    end
    # ----------------------------------------------------

  # ---------- New bow implementation with simulated Fz ----------
    # def bow(bow_dir, note_dur, bow_poses):
    # if note_dur > 3:
